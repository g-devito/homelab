services:
  db:
    image: mariadb:10.11
    container_name: seafile-mysql
    restart: always
    environment:
      - MYSQL_ROOT_PASSWORD={{ seafile_db_root_password }}
      - MYSQL_DATABASE=seafile_db
      - MYSQL_USER=seafile
      - MYSQL_PASSWORD={{ seafile_db_password }}
    volumes:
      - /opt/homelab/seafile/db:/var/lib/mysql
    labels:
      - "backup.manage=true"
    networks:
      - seafile-internal

  memcached:
    image: memcached:1.6
    container_name: seafile-memcached
    restart: always
    networks:
      - seafile-internal

  seafile:
    image: seafileltd/seafile-mc:latest
    container_name: seafile
    restart: always
    volumes:
      - /opt/homelab/seafile/data:/shared
    environment:
      - DB_HOST=db
      - DB_ROOT_PASSWD={{ seafile_db_root_password }}
      - TIME_ZONE=Europe/Rome
      - SEAFILE_ADMIN_EMAIL={{ seafile_admin_email }}
      - SEAFILE_ADMIN_PASSWORD={{ seafile_admin_password }}
      - SITE_TITLE=GionetDrive
      - SEAFILE_SERVER_HOSTNAME={{ seafile_server_hostname }}
      - SEAFILE_SERVER_PROTOCOL=https
    labels:
      - "backup.manage=true"
      - "traefik.enable=true"
      - "traefik.http.routers.seafile.rule=Host(`{{ seafile_server_hostname }}`)"
      - "traefik.http.routers.seafile.entrypoints=https"
      - "traefik.http.routers.seafile.tls.certresolver=letsencrypt"
      - "traefik.http.services.seafile.loadbalancer.server.port=80"
      - "traefik.docker.network=traefik-proxy"
    depends_on:
      - db
      - memcached
    networks:
      - seafile-internal
      - traefik-proxy

networks:
  seafile-internal:
    driver: bridge
  traefik-proxy:
    external: true
